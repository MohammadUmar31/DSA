vector<int> getSpans(int prices[], int m) {
        stack<int> stk;
        vector<int> ans;
        for(int i=0;i<m;i++){
            while(!stk.empty() && prices[stk.top()]<=prices[i]){
                stk.pop();
            }
            if(stk.empty()){
                ans.push_back(i+1);
            }
            else{
                ans.push_back(i-stk.top());
            }
            stk.push(i);
        }
        return ans;
    }
