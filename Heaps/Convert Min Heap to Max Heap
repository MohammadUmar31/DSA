void down_heapify(int i,vector<int>& arr){
        int n=arr.size();
        int l=2*i+1;
        int r=2*i+2;
        int maxi=i;
        if(l<n && arr[l]>arr[maxi]) maxi=l;
        if(r<n && arr[r]>arr[maxi]) maxi=r;
        if(maxi!=i){
            swap(arr[i],arr[maxi]);
            down_heapify(maxi,arr);
        }
    }
    void minToMaxHeap(vector<int>& arr) {
        int n=arr.size();
        for(int i=n/2-1;i>=0;i--){
            down_heapify(i,arr);
        }
    }
