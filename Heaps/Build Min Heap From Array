void downheapify(vector<int>& arr, int n, int i){
        int mini=i;
        int left=2*i+1;
        int right=2*i+2;
        if(left<n && arr[left]<arr[mini]) mini=left;
        if(right<n && arr[right]<arr[mini]) mini=right;
        if(mini!=i){
            swap(arr[i],arr[mini]);
            downheapify(arr,n,mini);
        }
    }
    void buildMinHeap(vector<int>& nums) {
        int n=nums.size();
        for(int i=n/2-1;i>=0;i--){
            downheapify(nums,n,i);
        }
    }
